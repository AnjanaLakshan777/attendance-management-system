<AnchorPane fx:id="ancEnrollToCourse" prefHeight="426.0" prefWidth="581.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.self.sams.controller.EnrollToCoursesController">
   <children>
      <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backToStudent" style="-fx-background-color: #0d6cd9; -fx-font-weight: bold;" text="Back" textFill="WHITE" />
      <ComboBox fx:id="comboCourse" layoutX="104.0" layoutY="67.0" prefHeight="25.0" prefWidth="371.0" />
      <Label layoutX="14.0" layoutY="66.0" prefHeight="27.0" prefWidth="59.0" style="-fx-font-weight: bold;" text="Course">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="14.0" layoutY="106.0" prefHeight="27.0" prefWidth="72.0" style="-fx-font-weight: bold;" text="Student">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboStudent" layoutX="104.0" layoutY="107.0" prefHeight="25.0" prefWidth="371.0" />
      <TableView fx:id="tblEnrollment" layoutX="15.0" layoutY="252.0" prefHeight="150.0" prefWidth="552.0">
         <columns>
            <TableColumn fx:id="colRegNo" prefWidth="72.0" text="Reg.No" />
            <TableColumn fx:id="colStudentName" prefWidth="127.0" text="StudentName" />
            <TableColumn fx:id="colCourseName" prefWidth="194.0" text="CourseName" />
            <TableColumn fx:id="colBatch" prefWidth="86.0" text="Batch" />
             <TableColumn fx:id="colStatus" prefWidth="81.0" text="Status" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="499.0" layoutY="66.0" mnemonicParsing="false" onAction="#searchCourse" prefHeight="27.0" prefWidth="54.0" style="-fx-background-color: #ab66e3; -fx-font-weight: bold;" text="Search" textFill="WHITE" />
      <Button layoutX="499.0" layoutY="106.0" mnemonicParsing="false" onAction="#searchStudent" prefHeight="27.0" prefWidth="54.0" style="-fx-background-color: #ab66e3; -fx-font-weight: bold;" text="Search" textFill="WHITE" />
      <Button layoutX="475.0" layoutY="200.0" mnemonicParsing="false" onAction="#clickEnroll" prefHeight="27.0" prefWidth="92.0" style="-fx-font-weight: bold; -fx-background-color: #0d6cd9;" text="Enroll" textFill="WHITE">
