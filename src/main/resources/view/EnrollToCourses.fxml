      </Button>
      <Button layoutX="263.0" layoutY="200.0" mnemonicParsing="false" onAction="#clickUnenroll" prefHeight="27.0" prefWidth="92.0" style="-fx-font-weight: bold; -fx-background-color: red;" text="Unenroll" textFill="WHITE">
         <font>
            <Font size="13.0" />
