<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="ancLecturerDash" prefHeight="400.0" prefWidth="603.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.self.sams.controller.LecturerDashboardController">
   <children>
      <Pane prefHeight="51.0" prefWidth="603.0" style="-fx-background-color: #d8deeb;">
         <children>
            <Button layoutX="510.0" layoutY="13.0" mnemonicParsing="false" onAction="#logOut" prefHeight="27.0" prefWidth="74.0" style="-fx-font-weight: bold; -fx-background-color: red;" text="Log out" textFill="WHITE">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Label fx:id="lblTitle" layoutX="21.0" layoutY="13.0" prefHeight="27.0" prefWidth="237.0" style="-fx-background-color: #d8deeb; -fx-font-weight: bold;" text=" ">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </Pane>
      <Label layoutX="21.0" layoutY="59.0" style="-fx-font-style: italic;" text="Upcoming Classes...">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <TableView fx:id="tblScheduleClass" layoutX="17.0" layoutY="89.0" prefHeight="225.0" prefWidth="570.0">
        <columns>
          <TableColumn fx:id="colDate" prefWidth="73.0" text="Date" />
          <TableColumn fx:id="colStartTime" prefWidth="63.0" text="Start Time" />
           <TableColumn fx:id="colEndTime" prefWidth="58.0" text="End Time" />
           <TableColumn fx:id="colSubjectName" prefWidth="159.0" text="Subject Name" />
           <TableColumn fx:id="colBatch" prefWidth="36.0" text="Batch" />
           <TableColumn fx:id="colCourseName" prefWidth="176.0" text="Course Name" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="460.0" layoutY="337.0" mnemonicParsing="false" onAction="#clickOnMarkAttendance" prefHeight="34.0" prefWidth="127.0" style="-fx-font-weight: bold; -fx-background-color: #0d6cd9;" text="Mark Attendance" textFill="WHITE">
         <font>
            <Font size="13.0" />
         </font>
      </Button>
      <Button layoutX="21.0" layoutY="337.0" mnemonicParsing="false" onAction="#clickOnDone" prefHeight="34.0" prefWidth="127.0" style="-fx-font-weight: bold; -fx-background-color: green;" text="Set as Done" textFill="WHITE">
         <font>
            <Font size="13.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
