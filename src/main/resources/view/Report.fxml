<AnchorPane fx:id="ancReport" prefHeight="506.0" prefWidth="715.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.self.sams.controller.ReportController">
